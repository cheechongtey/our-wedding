# Copy to .env.local and fill in (never commit .env.local).
# Notion: https://www.notion.so/my-integrations → New integration → copy "Internal Integration Secret"
NOTION_TOKEN=

# Open your RSVP database in Notion; the ID is the 32-char hex in the URL:
# https://www.notion.so/workspace/DATABASE_ID?v=...
NOTION_RSVP_DB_ID=
